# Copie ce fichier en ".env" et remplis tes valeurs.
# Ne jamais committer le fichier .env dans Git !

# --- LLM (optionnel, résumés plus beaux) ---
# Clé gratuite : https://aistudio.google.com/app/apikey  (sans CB)
GEMINI_API_KEY=

# --- Données cartes (optionnel, améliore les prix USD) ---
# Clé gratuite : https://dev.pokemontcg.io/  (sans CB)
POKEMONTCG_API_KEY=

# --- Email : choisir UNE option ---

# Option A : Gmail SMTP (simple, gratuit, pour envoi perso)
GMAIL_USER=ton.adresse@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Option B : Brevo (gratuit 300 mails/jour, pour liste d'abonnés)
BREVO_API_KEY=

# --- Destinataires newsletter (séparés par des virgules) ---
NEWSLETTER_RECIPIENTS=ton.adresse@gmail.com
